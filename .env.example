# ── Telegram (Scraper account) ──────────────────────────────────────────────
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Generated by running the app and completing the Telegram → Settings tab OTP flow
# Or run: python generate_session.py
TELEGRAM_SESSION_STRING=

# ── Telegram (Notification bot) ─────────────────────────────────────────────
# Create a bot via @BotFather, paste the token here
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (message @userinfobot to get it)
TELEGRAM_CHAT_ID=

# ── Binance ──────────────────────────────────────────────────────────────────
# For testnet: https://testnet.binancefuture.com
BINANCE_API_KEY=
BINANCE_SECRET=
BINANCE_TESTNET=true

# ── AI ───────────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com
# Leave blank to use mock mode (AI_MOCK_MODE=true)
ANTHROPIC_API_KEY=

# ── App config ───────────────────────────────────────────────────────────────
AI_MOCK_MODE=true          # true = no API calls, simulated scores (FREE)
PAPER_MODE=true            # true = no real orders placed

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-string-in-production
